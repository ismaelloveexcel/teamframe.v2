# Example environment for the API server (artifacts/api-server) and lib/db.
# Copy to .env and fill in real values. Do NOT commit your real .env.

# --- Required ---

# Postgres connection string used by lib/db (the runtime `db`/`pool`).
# In PRODUCTION this MUST point at the NOLOGIN-then-LOGIN-enabled `app_user`
# role (NOBYPASSRLS) so row-level security applies — never a superuser.
# See docs/hr/DEPLOYMENT.md §2 and §4a.
DATABASE_URL=postgresql://app_user:app_user_pw@localhost:5432/teamframe

# HTTP port the API server listens on. Required — the server throws on startup
# if PORT is missing or not a positive number (artifacts/api-server/src/index.ts).
PORT=3000

# --- Optional ---

# Logging (artifacts/api-server/src/lib/logger.ts).
# NODE_ENV=production switches the logger out of pretty-print mode.
NODE_ENV=development
# Pino log level: trace|debug|info|warn|error|fatal (default: info).
LOG_LEVEL=info
