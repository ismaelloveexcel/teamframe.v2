{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:phase-core": "tsx --test \"src/domain/**/__tests__/*.test.ts\"",
    "test:founder-cert": "tsx ./src/founder-flow-certification.ts",
    "test:phase3-cert": "tsx ./src/phase3-certification.ts",
    "test:phase4-cert": "tsx ./src/phase4-certification.ts",
    "test:phase4-validation": "tsx ./src/phase4-determinism-validation.ts",
    "test:system-stability-audit": "tsx ./src/system-stability-audit.ts",
    "test:phase4-stabilization": "tsx ./src/phase4-stabilization.ts",
    "test:determinism-enforcement": "tsx ./src/determinism-enforcement.test.ts",
    "test:phase4-independent-verify": "tsx ./src/phase4-independent-verification.ts",
    "test:system-certification-audit": "tsx ./src/system-certification-audit.ts",
    "test:stability-closure1": "tsx ./src/stability-closure1-replay.ts --apply",
    "test:stability-closure3": "tsx ./src/stability-closure3-repair-cert.ts",
    "test:stability-closure4": "tsx ./src/stability-closure4-malformed-cert.ts"
  },
  "dependencies": {
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
}
