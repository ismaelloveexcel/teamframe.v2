{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:phase-core": "tsx --test \"src/domain/**/__tests__/*.test.ts\"",
    "rls-gate": "tsx src/__rls_check__/rls-gate.ts",
    "runtime-rls-gate": "tsx src/__rls_check__/runtime-rls-gate.ts",
    "appuser-prod-gate": "tsx src/__rls_check__/appuser-prod-gate.ts",
    "audit-gate": "tsx src/__rls_check__/audit-gate.ts",
    "position-gate": "tsx src/__rls_check__/position-gate.ts",
    "employee-gate": "tsx src/__rls_check__/employee-gate.ts",
    "orgchart-gate": "tsx src/__rls_check__/orgchart-gate.ts",
    "compensation-gate": "tsx src/__rls_check__/compensation-gate.ts",
    "leave-gate": "tsx src/__rls_check__/leave-gate.ts",
    "policy-gate": "tsx src/__rls_check__/policy-gate.ts",
    "document-gate": "tsx src/__rls_check__/document-gate.ts",
    "offboarding-gate": "tsx src/__rls_check__/offboarding-gate.ts",
    "report-gate": "tsx src/__rls_check__/report-gate.ts",
    "activation-gate": "tsx src/__rls_check__/activation-gate.ts",
    "report-render-gate": "tsx src/__rls_check__/report-render-gate.ts"
  },
  "dependencies": {
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
}
