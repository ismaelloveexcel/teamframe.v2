{
  "flow": "Flow #1 — Onboarding → First Value Moment",
  "version": "1.0",
  "events": [
    {
      "id": "fe-1",
      "name": "app_loading_started",
      "trigger": "TeamFrame component mounts",
      "properties": { "mode": "api | demo" },
      "purpose": "Measure drop-off during load phase"
    },
    {
      "id": "fe-2",
      "name": "app_loading_completed",
      "trigger": "loading state becomes false",
      "properties": { "duration_ms": "number", "org_exists": "boolean", "positions_count": "number" },
      "purpose": "Measure load success rate and initial org state"
    },
    {
      "id": "fe-3",
      "name": "empty_org_guide_shown",
      "trigger": "EmptyOrgGuide renders (positions.length === 0)",
      "properties": { "is_demo_mode": "boolean" },
      "purpose": "Measure how many users hit empty state"
    },
    {
      "id": "fe-4",
      "name": "empty_org_cta_clicked",
      "trigger": "User clicks 'Create first position' in EmptyOrgGuide",
      "properties": {},
      "purpose": "Measure empty-state CTA conversion rate"
    },
    {
      "id": "fe-5",
      "name": "first_position_created",
      "trigger": "positions.length transitions from 0 to 1",
      "properties": { "title": "string" },
      "purpose": "First value moment trigger — track activation rate"
    },
    {
      "id": "fe-6",
      "name": "org_ready_banner_shown",
      "trigger": "OrgReadyBanner renders after first position",
      "properties": { "trigger": "first_position | first_assignment" },
      "purpose": "Measure first-value moment impression"
    },
    {
      "id": "fe-7",
      "name": "org_ready_banner_assign_clicked",
      "trigger": "User clicks 'Assign person' in OrgReadyBanner",
      "properties": {},
      "purpose": "Measure follow-through from first position to first assignment"
    },
    {
      "id": "fe-8",
      "name": "first_assignment_created",
      "trigger": "positionAssignmentById.size transitions from 0 to 1",
      "properties": { "position_id": "string" },
      "purpose": "Full activation — user has a filled org chart"
    },
    {
      "id": "fe-9",
      "name": "nav_item_clicked",
      "trigger": "User clicks sidebar nav item",
      "properties": { "from": "NavId", "to": "NavId" },
      "purpose": "Understand navigation patterns and drop-off by section"
    }
  ],
  "funnelDefinition": {
    "stages": [
      { "stage": 1, "event": "app_loading_completed",    "label": "Loaded" },
      { "stage": 2, "event": "empty_org_guide_shown",    "label": "Saw empty state" },
      { "stage": 3, "event": "empty_org_cta_clicked",    "label": "Clicked CTA" },
      { "stage": 4, "event": "first_position_created",   "label": "Created first position" },
      { "stage": 5, "event": "first_assignment_created", "label": "Filled first position" }
    ],
    "conversionGoal": "first_assignment_created",
    "targetConversionRate": 0.6
  }
}
